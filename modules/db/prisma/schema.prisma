datasource db {
  provider = "sqlite"
  url      = "file:communism.db"
}

generator client {
  provider             = "prisma-client-py"
  interface            = "sync"
  recursive_type_depth = 5
}

model Project {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  clusterId   String
}
